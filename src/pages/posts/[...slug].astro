---
import { getCollection, render } from "astro:content";
import MarkdownPostLayoutAstroComponent from "../../layouts/MarkdownPostLayout.astro";

export const getStaticPaths = async () => {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
};

const { post } = Astro.props;
const { Content } = await render(post);
---

<MarkdownPostLayoutAstroComponent frontmatter={post.data}>
    <Content />
</MarkdownPostLayoutAstroComponent>
