---

---
  <form class="bg-transparent shadow-md dark:border rounded dark:border-gray-700 px-8 pt-6 pb-8 mb-4">
    <h3 class="text-3xl justify-center">Contact</h3>
    <div class="mb-4">
      <label class="block text-gray-700 dark:text-gray-600 text-sm font-bold mb-2" for="username">
        Name
      </label>
      <input class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 dark:text-gray-600 leading-tight focus:outline-none focus:shadow-outline" id="username" type="text" placeholder="Username">
    </div>
    <div class="mb-6">
      <label class="block text-gray-700 dark:text-gray-600 text-sm font-bold mb-2" for="password">
        Email
      </label>
      <input class="shadow appearance-none border border-red-500  dark:bg-gray-700 rounded w-full py-2 px-3 text-gray-700 dark:text-gray-600 mb-3 leading-tight focus:outline-none focus:shadow-outline" id="password" type="password" placeholder="******************">
      <p class="text-red-500 text-xs italic">Please choose a password.</p>
    </div>
    <div class="mb-4">
        <textarea name="message" class="w-full border rounded-md dark:bg-gray-700 p-1 min-h-20 resize-none"></textarea>
    </div>
    <div class="flex items-center justify-between">
      <button class="bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded focus:outline-none focus:shadow-outline" type="button">
        Contact Us
      </button>
    </div>
  </form>
