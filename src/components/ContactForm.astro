---

<div class="wrapper">
  <form
    id="contact-form"
    class="flex flex-col bg-transparent shadow-md dark:border rounded dark:border-gray-700 px-8 pt-6 pb-8 mb-4"
  >
    <h3 class="text-3xl text-amber-600 text-center">Contact</h3>
    <div class="mb-4">
      <label
        class="block text-gray-700 dark:text-gray-600 text-sm font-bold mb-2"
        for="name"
      >
        Name
      </label>
      <input
        class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 dark:text-gray-600 leading-tight focus:outline-none focus:shadow-outline"
        id="name"
        type="text"
        placeholder="John Doe"
      />
    </div>
    <div class="mb-6">
      <label
        class="block text-gray-700 dark:text-gray-600 text-sm font-bold mb-2"
        for="email"
      >
        Email
      </label>
      <input
        class="shadow appearance-none border border-red-500 dark:bg-gray-700 rounded w-full py-2 px-3 text-gray-700 dark:text-gray-600 mb-3 leading-tight focus:outline-none focus:shadow-outline"
        id="email"
        type="email"
        placeholder="john@example.com"
      />
      <p class="text-red-500 text-xs italic">Please enter a email.</p>
    </div>
    <div class="mb-4">
      <textarea
        name="message"
        id="message"
        class="w-full border rounded-md dark:bg-gray-700 p-1 min-h-20 resize-none"
      ></textarea>
    </div>
    <div class="flex items-center justify-between">
      <button
        class="w-full bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded focus:outline-none focus:shadow-outline"
        type="submit"
      >
        Contact Us
      </button>
    </div>
  </form>
  <!-- Loading -->
  <div
    id="contact-loading"
    class="flex flex-col items-center justify-center bg-yellow-400 text-white px-8 py-16 mb-4 rounded"
  >
    <h3 class="text-3xl">Loading...</h3>
  </div>
  <!-- Success Panel -->
  <div
    id="contact-success"
    class="flex flex-col rounded items-center justify-center bg-green-600 text-white"
  >
    <h3 class="text-3xl mb-3">Success</h3>
    <p>Your contact was uploaded successfully.</p>
  </div>
  <!-- Failure Panel -->
  <div
    id="contact-failure"
    class="flex flex-col rounded items-center justify-center bg-red-600 text-white"
  >
    <h3 class="text-3xl mb-3">Failure</h3>
    <p>Your contact form was unsuccessful.</p>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    // panels
    const form = document.querySelector("#contact-form") as HTMLFormElement;
    const loading = document.querySelector<Element>("#contact-loading");
    const success = document.querySelector<Element>("#contact-success");
    const failure = document.querySelector<Element>("#contact-failure");
    const panels = [form, loading, success, failure];

    // form fields
    const name = form?.querySelector<HTMLInputElement>("#name");
    const email = form?.querySelector<HTMLInputElement>("#email");
    const message = form?.querySelector("#message");

    const showPanel = (panel: Element) => {
      panels.forEach((el) => el?.classList.remove("active"));
      panel.classList.add("active");
    };

    // Don't forget to show the form right away
    showPanel(form)

    form?.addEventListener("submit", (e) => {
      e.preventDefault();
      showPanel(loading);
      alert(name?.value);

      setTimeout(() => {
        showPanel(success);
      }, 1000);
    });
  });
</script>
<style>
  .wrapper {
    /* wrapper */
    display: grid;
    grid-template-areas: "panel";
  }
  /* all children */
  .wrapper > * {
    grid-area: panel;
    visibility: hidden;
    opacity: 0;
  }

  .wrapper > .active {
    visibility: visible;
    opacity: 1;
  }
</style>
