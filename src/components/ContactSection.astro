---
import Hero from "./Hero.astro";
import ContactForm from "./ContactForm.astro";
import contactHero from "../images/contact.jpeg";
---

<div id="contact">
  <Hero image={contactHero} title="projects">
    <div class="hero-text m-2">Get In Touch</div>
    <button
      id="contactButton"
      class="bg-special-yellow dark:bg-dark-special-yellow text-vermillion dark:text-vermillion rounded-xl p-3"
      >Learn More</button
    >
  </Hero>
  <section
    id="contact-content"
    class="grid grid-cols-1 md:grid-cols-2 gap-6 p-6 items-stretch min-h-100"
  >
    <div class="min-h-100 md:h-full flex flex-col justify-start items-center">
      <h2 class="text-2xl text-center m-6">Contact Us</h2>
      <p>
        If you would like to get in touch for building a project for you or
        would like to make a query to us, use the adjacent form and we will be
        in contact shortly.
      </p>
    </div>
    <div class="h-full">
      <ContactForm />
    </div>
  </section>
  <>
    <script>
      import ctaScrollIntoView from "../scripts/ctaScrollIntoView";

      const actionButton = document.querySelector(
        "#contactButton",
      ) as HTMLButtonElement;
      const targetSection = document.querySelector("#contact-content");

      ctaScrollIntoView(actionButton, targetSection);
    </script></>
</div>
