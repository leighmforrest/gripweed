---
const { name, imageUrl, icons } = Astro.props;
console.log(icons);
import { Image } from "astro:assets";
import Icon from "./Icon";

console.log(icons)
---

<div
  class="project-card bg-gray-50 dark:bg-gray-800 flex flex-col items-center aspect-3/4 md:aspect-3/4
rounded-xl overflow-hidden shadow-xl"
>
  <div class="w-full">
    <Image
      src="https://placehold.co/400"
      inferSize={true}
      alt="About Gripweed Consulting"
      class="w-full h-full object-cover aspect-square"
    />
  </div>
  <div class="flex flex-col gap-0.5">
    <h3 class="text-3xl pt-1">{name}</h3>
    <div class="flex">
      {icons?.map((icon) => (<Icon name={icon.name} set={icon.set}/>))}
    </div>
  </div>
</div>
