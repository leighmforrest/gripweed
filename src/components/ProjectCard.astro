---
const { name, imageUrl, githubUrl, webUrl,  icons } = Astro.props;
import { Image } from "astro:assets";
import Icon from "./Icon";
---

<div
  class="project-card bg-gray-50 dark:bg-gray-800 flex flex-col items-center
rounded-xl overflow-hidden shadow-xl"
>
  <div class="w-full">
    <Image
      src="https://placehold.co/400"
      inferSize={true}
      alt="About Gripweed Consulting"
      class="w-full h-full object-cover aspect-square"
    />
  </div>
  <div class="flex flex-col gap-0.5 w-full p-2 justify-center items-center">
    <div class="card-title pt-1">{name}</div>
    <div class="flex justify-between items-center w-full p-2  text-vermillion dark:text-dark-special-yellow">
        <span class="flex gap-2">
        <a href={githubUrl}>
            <Icon name="FaGithub" set="fa6" />
        </a>
        {webUrl && <a href={webUrl}>
            <Icon name="CiGlobe" set="ci" />
        </a>}
    </span>
    <span class="flex gap-2">
      {icons?.map((icon) => (<Icon name={icon.name} set={icon.set} />))}
    </span>
    </div>
    
  </div>
</div>
